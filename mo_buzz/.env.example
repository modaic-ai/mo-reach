# mo_buzz environment variables.
# Locally: copy to `.env` and fill in values. In Modal these live in a secret
# named `mo-buzz` (see README).
#
# Keep comments on their OWN lines (not after a value) so the loader doesn't
# treat the comment as part of the value.

# --- Modaic ---
# MODAIC_TOKEN: https://modaic.dev/settings/tokens
MODAIC_TOKEN=
# MODAIC_USER_OR_ORG: owner of <org>/reddit-post-judge
MODAIC_USER_OR_ORG=modaic

# --- Reddit ---
# REDDIT_SOURCE=api uses the official API (PRAW) and needs the creds below.
# REDDIT_SOURCE=rss uses public Atom feeds and needs no creds (good while you
# wait on API approval).
REDDIT_SOURCE=rss
# Only required when REDDIT_SOURCE=api (create a "script" app at
# https://www.reddit.com/prefs/apps):
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=mo_buzz/0.1 (by Modaic)

# --- Slack (from your Slack app config) ---
# SLACK_BOT_TOKEN: xoxb-... (bot scope chat:write)
SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET: Basic Information -> App Credentials
SLACK_SIGNING_SECRET=
# SLACK_CHANNEL_ID: e.g. C0123ABCD (invite the bot to this channel)
SLACK_CHANNEL_ID=

# --- Optional tuning (defaults shown) ---
# LOOKBACK_HOURS=24
# POSTS_PER_SUBREDDIT=50
