# mo_buzz environment variables.
# Locally: copy to `.env` and `source` it (or export). In Modal these live in
# a secret named `mo-buzz` (see README).

# --- Modaic ---
MODAIC_TOKEN=                 # https://modaic.dev/settings/tokens
MODAIC_USER_OR_ORG=modaic     # owner of <org>/reddit-post-judge

# --- Reddit (create a "script" app at https://www.reddit.com/prefs/apps) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=mo_buzz/0.1 (by Modaic)

# --- Slack (from your Slack app config) ---
SLACK_BOT_TOKEN=              # xoxb-...  (scopes: chat:write)
SLACK_SIGNING_SECRET=         # Basic Information -> App Credentials
SLACK_CHANNEL_ID=             # e.g. C0123ABCD

# --- Optional tuning (defaults shown) ---
# LOOKBACK_HOURS=24
# POSTS_PER_SUBREDDIT=50
